<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Tech Blog{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/logo.png') }}" type="image/png">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
        <style>
            [data-theme="dark"] {
                --color-primary: #0f172a;
                --color-primary-light: #1e293b;
                --color-accent: #6366f1;
                --color-accent-hover: #4f46e5;
                --color-accent-glow: rgba(99, 102, 241, 0.4);
                --color-text: #f1f5f9;
                --color-text-muted: #94a3b8;
                --color-bg: #0f172a;
                --color-bg-card: rgba(255,255,255,0.03);
                --color-card: rgba(255,255,255,0.05);
                --color-border: rgba(255,255,255,0.1);
                --color-header-bg: rgba(15,23,42,0.95);
                --color-header-text: rgba(255,255,255,0.9);
                --shadow-glow: 0 0 40px rgba(99, 102, 241, 0.15);
                --shadow-card: 0 8px 32px rgba(0,0,0,0.2);
                --bg-overlay: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.25), transparent),
                    radial-gradient(ellipse 60% 40% at 100% 50%, rgba(139, 92, 246, 0.15), transparent),
                    radial-gradient(ellipse 60% 40% at 0% 80%, rgba(59, 130, 246, 0.1), transparent);
            }
            [data-theme="light"] {
                --color-primary: #1e293b;
                --color-primary-light: #334155;
                --color-accent: #6366f1;
                --color-accent-hover: #4f46e5;
                --color-accent-glow: rgba(99, 102, 241, 0.25);
                --color-text: #1e293b;
                --color-text-muted: #64748b;
                --color-bg: #f8fafc;
                --color-bg-card: rgba(255,255,255,0.8);
                --color-card: rgba(255,255,255,0.95);
                --color-border: rgba(0,0,0,0.08);
                --color-header-bg: rgba(255,255,255,0.95);
                --color-header-text: #1e293b;
                --shadow-glow: 0 0 40px rgba(99, 102, 241, 0.1);
                --shadow-card: 0 4px 20px rgba(0,0,0,0.08);
                --bg-overlay: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.08), transparent),
                    radial-gradient(ellipse 60% 40% at 100% 50%, rgba(139, 92, 246, 0.05), transparent);
            }
            :root, [data-theme="dark"] {
                --radius: 12px;
                --radius-lg: 16px;
                --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            * { box-sizing: border-box; }
            html { scroll-behavior: smooth; }
            body {
                font-family: 'Outfit', system-ui, sans-serif;
                margin: 0; padding: 0; line-height: 1.6;
                display: flex; flex-direction: column; min-height: 100vh;
                background: var(--color-bg); color: var(--color-text);
                overflow-x: hidden; transition: background var(--transition), color var(--transition);
            }
            body::before {
                content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
                background: var(--bg-overlay);
                pointer-events: none; z-index: 0;
            }

            header {
                background: var(--color-header-bg);
                backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
                color: var(--color-header-text); padding: 1rem 2rem;
                box-shadow: 0 4px 30px rgba(0,0,0,0.1);
                position: sticky; top: 0; z-index: 100;
                border-bottom: 1px solid var(--color-border);
                animation: slideDown 0.6s ease;
            }
            header nav {
                display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
                max-width: 1200px; margin: 0 auto; gap: 1rem;
            }
            header .logo { height: 44px; transition: transform var(--transition), filter var(--transition); }
            header a:hover .logo { transform: scale(1.08) rotate(-2deg); filter: drop-shadow(0 0 12px var(--color-accent-glow)); }
            .header-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
            .search-form { display: flex; gap: 0.5rem; }
            .search-form input {
                padding: 0.5rem 1rem; border-radius: var(--radius); border: 1px solid var(--color-border);
                background: var(--color-card); color: var(--color-text); font-size: 0.9rem;
                width: 180px; transition: width var(--transition), border-color var(--transition);
            }
            .search-form input:focus { outline: none; border-color: var(--color-accent); width: 220px; }
            .search-form input::placeholder { color: var(--color-text-muted); }
            .theme-toggle {
                background: var(--color-card); border: 1px solid var(--color-border);
                padding: 0.5rem 0.75rem; border-radius: var(--radius); cursor: pointer;
                color: var(--color-text); transition: all var(--transition);
                display: flex; align-items: center; justify-content: center;
            }
            .theme-toggle:hover { background: var(--color-accent); color: white; border-color: var(--color-accent); }
            .theme-toggle .icon-sun, .theme-toggle .icon-moon { display: none; }
            .theme-toggle[data-theme="light"] .icon-moon { display: block; }
            .theme-toggle[data-theme="dark"] .icon-sun { display: block; }
            header .menu { list-style: none; display: flex; gap: 0.5rem; margin: 0; padding: 0; }
            header .menu a {
                color: var(--color-header-text); text-decoration: none; font-weight: 500;
                padding: 0.5rem 1rem; border-radius: var(--radius);
                transition: all var(--transition);
            }
            header .menu a:hover {
                background: var(--color-accent); color: white;
                transform: translateY(-2px);
            }

            main { flex: 1; max-width: 1200px; margin: 0 auto; padding: 2rem; width: 100%; position: relative; z-index: 1; }
            footer {
                background: var(--color-primary); color: rgba(255,255,255,0.8);
                text-align: center; padding: 1.5rem; margin-top: auto;
                border-top: 1px solid var(--color-border);
                animation: fadeIn 1s ease 0.3s both;
            }
            [data-theme="light"] footer { background: var(--color-primary-light); }
            .footer-links { margin-bottom: 1.5rem; }
            .footer-nav { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 0.5rem; }
            .footer-nav a { color: rgba(255,255,255,0.9); text-decoration: none; font-weight: 500; transition: color var(--transition); }
            .footer-nav a:hover { color: white; text-decoration: underline; }
            .footer-newsletter { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.2); }
            .footer-title { font-weight: 600; margin: 0 0 0.25rem; font-size: 1rem; }
            .footer-desc { font-size: 0.9rem; margin: 0 0 1rem; opacity: 0.9; }
            .newsletter-form { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto; justify-content: center; flex-wrap: wrap; }
            .newsletter-form input { flex: 1; min-width: 200px; padding: 0.5rem 1rem; border-radius: var(--radius); border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.1); color: white; }
            .newsletter-form input::placeholder { color: rgba(255,255,255,0.6); }
            .footer-copy { margin: 0; font-size: 0.9rem; opacity: 0.8; }

            .hero-title {
                font-size: 2.25rem; font-weight: 700; margin-bottom: 0.5rem;
                background: linear-gradient(135deg, var(--color-text) 0%, var(--color-text-muted) 100%);
                -webkit-background-clip: text; -webkit-text-fill-color: transparent;
                background-clip: text; animation: fadeInUp 0.6s ease;
            }
            h1 { font-size: 1.75rem; margin-bottom: 0.5rem; color: var(--color-text); }
            .post-title { font-size: 2rem; font-weight: 700; color: var(--color-text); animation: fadeInUp 0.5s ease; }
            h2 { font-size: 1.25rem; margin: 1.5rem 0 0.75rem; color: var(--color-text); }
            .lead { color: var(--color-text-muted); font-size: 1.15rem; margin-bottom: 2rem; animation: fadeInUp 0.6s ease 0.1s both; }

            .post-card {
                background: var(--color-card); border: 1px solid var(--color-border);
                padding: 1.75rem; margin-bottom: 1.5rem; border-radius: var(--radius-lg);
                backdrop-filter: blur(10px); box-shadow: var(--shadow-card);
                transition: all var(--transition);
                animation: fadeInUp 0.5s ease forwards;
                position: relative; overflow: hidden;
            }
            .post-card::before {
                content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
                background: linear-gradient(90deg, var(--color-accent), #8b5cf6);
                opacity: 0; transform: scaleX(0); transform-origin: left;
                transition: all var(--transition);
            }
            .post-card:nth-child(1) { animation-delay: 0.08s; }
            .post-card:nth-child(2) { animation-delay: 0.16s; }
            .post-card:nth-child(3) { animation-delay: 0.24s; }
            .post-card:nth-child(4) { animation-delay: 0.32s; }
            .post-card:nth-child(5) { animation-delay: 0.4s; }
            .post-card:hover {
                transform: translateY(-6px) scale(1.01);
                box-shadow: var(--shadow-card), var(--shadow-glow);
                border-color: rgba(99, 102, 241, 0.3);
            }
            .post-card:hover::before { opacity: 1; transform: scaleX(1); }
            .post-card h2 a { color: var(--color-text); text-decoration: none; font-weight: 600; transition: all var(--transition); }
            .post-card h2 a:hover { color: var(--color-accent); }
            .post-card p { color: var(--color-text-muted); }
            .read-more {
                display: inline-block; margin-top: 1rem; font-size: 0.9rem; font-weight: 600;
                color: var(--color-accent); text-decoration: none;
                transition: color var(--transition), transform var(--transition);
            }
            .read-more:hover { color: var(--color-accent-hover); transform: translateX(4px); }
            .read-more::after { content: ' →'; }

            .badge {
                display: inline-block; text-decoration: none;
                background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
                color: white; padding: 0.3rem 0.75rem; border-radius: 9999px;
                font-size: 0.75rem; font-weight: 600; margin-right: 0.5rem; margin-bottom: 0.25rem;
                transition: all var(--transition);
            }
            .badge:hover { transform: scale(1.1); color: white; }

            .category-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; }
            .category-card {
                display: block; padding: 2rem; border-radius: var(--radius-lg);
                background: var(--color-card); border: 1px solid var(--color-border);
                text-decoration: none; color: var(--color-text);
                transition: all var(--transition); animation: fadeInUp 0.5s ease forwards;
            }
            .category-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card); border-color: var(--color-accent); }
            .category-card h2 { margin: 0 0 0.5rem; font-size: 1.25rem; }
            .category-count { font-size: 0.9rem; color: var(--color-text-muted); }

            .contact-info { margin-top: 2rem; }
            .contact-item { margin-bottom: 1.5rem; }
            .contact-item strong { display: block; margin-bottom: 0.25rem; color: var(--color-accent); }
            .contact-item p { margin: 0; color: var(--color-text-muted); }

            .comment {
                border-left: 4px solid var(--color-accent);
                padding: 1.25rem; margin: 1rem 0;
                background: var(--color-card); border-radius: 0 var(--radius) var(--radius) 0;
                border: 1px solid var(--color-border); border-left-width: 4px;
                transition: all var(--transition);
                animation: slideInLeft 0.4s ease forwards;
            }
            .comment:hover { transform: translateX(8px); box-shadow: var(--shadow-card); }
            .comment strong { color: var(--color-text); }
            .comment p { color: var(--color-text-muted); }
            .comment-date { color: var(--color-text-muted); font-size: 0.85rem; margin-left: 0.5rem; }

            .alert-success, .alert.alert-success {
                background: rgba(16, 185, 129, 0.2); color: #059669;
                padding: 1rem; border-radius: var(--radius); margin: 1rem 0;
                border-left: 4px solid #10b981;
                animation: slideInLeft 0.4s ease, pulse 2s ease infinite;
            }
            [data-theme="dark"] .alert-success { color: #6ee7b7; }
            .alert-danger, .form-error {
                background: rgba(239, 68, 68, 0.2); color: #b91c1c;
                padding: 1rem; border-radius: var(--radius); margin: 1rem 0;
                list-style: none; border-left: 4px solid #ef4444;
            }
            [data-theme="dark"] .alert-danger { color: #fca5a5; }

            form div { margin: 1.25rem 0; }
            form label { display: block; margin-bottom: 0.4rem; font-weight: 600; color: var(--color-text); }
            form input, form textarea {
                width: 100%; max-width: 500px; padding: 0.75rem 1rem;
                border: 1px solid var(--color-border); border-radius: var(--radius);
                font-size: 1rem; background: var(--color-card); color: var(--color-text);
                transition: all var(--transition);
            }
            form input::placeholder, form textarea::placeholder { color: var(--color-text-muted); }
            form input:focus, form textarea:focus {
                outline: none; border-color: var(--color-accent);
                box-shadow: 0 0 0 3px var(--color-accent-glow);
            }
            form ul { list-style: none; padding: 0; margin: 0.5rem 0; }
            form li { margin: 0.5rem 0; display: flex; align-items: center; gap: 0.5rem; }
            form input[type="checkbox"] { width: auto; max-width: none; }

            .btn {
                background: linear-gradient(135deg, var(--color-accent), #8b5cf6);
                color: white; padding: 0.75rem 1.5rem; border: none; cursor: pointer;
                border-radius: var(--radius); font-weight: 600; font-size: 0.95rem;
                transition: all var(--transition);
                box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
            }
            .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(99, 102, 241, 0.5); }
            .btn:active { transform: translateY(0); }
            .btn-search { padding: 0.5rem 1rem; }

            .back-link {
                display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 2rem;
                color: var(--color-accent); text-decoration: none; font-weight: 600;
                transition: all var(--transition);
            }
            .back-link:hover { transform: translateX(-6px); }

            .post-content { line-height: 1.8; margin: 1rem 0; color: var(--color-text-muted); }
            .categories { margin: 0.75rem 0; }
            .post-detail {
                background: var(--color-card); padding: 2.5rem; border-radius: var(--radius-lg);
                border: 1px solid var(--color-border);
                backdrop-filter: blur(10px); box-shadow: var(--shadow-card);
                animation: fadeInUp 0.6s ease;
            }
            .comments h2 { color: var(--color-text); }
            .comments-list p { color: var(--color-text-muted); }
            .empty-state { color: var(--color-text-muted); font-style: italic; padding: 2rem; text-align: center; }

            .breadcrumb { font-size: 0.9rem; margin-bottom: 1.5rem; color: var(--color-text-muted); }
            .breadcrumb a { color: var(--color-accent); text-decoration: none; }
            .breadcrumb a:hover { text-decoration: underline; }
            .breadcrumb .sep { margin: 0 0.5rem; opacity: 0.6; }

            @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
            @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
            @keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
            @keyframes slideInLeft { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
            @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.9; } }

            @media (max-width: 768px) {
                header { padding: 1rem; }
                header nav { flex-direction: column; align-items: stretch; }
                .header-right { flex-direction: column; }
                .search-form input { width: 100%; }
                .search-form input:focus { width: 100%; }
                header .menu { flex-wrap: wrap; justify-content: center; }
                main { padding: 1rem; }
                .post-card { padding: 1.25rem; }
                .hero-title { font-size: 1.75rem; }
                form input, form textarea { max-width: 100%; }
            }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body data-theme="light">
        <header role="banner">
            <nav role="navigation" aria-label="Menu principal">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/logo.png') }}" alt="Tech Blog Logo" class="logo" onerror="this.src='{{ asset('images/logo.svg') }}'; this.onerror=null;">
                </a>
                <div class="header-right">
                    <form action="{{ path('app_search') }}" method="get" class="search-form">
                        <input type="search" name="q" placeholder="Rechercher..." value="{{ app.request.query.get('q') ?? '' }}" aria-label="Rechercher des articles">
                        <button type="submit" class="btn btn-search" aria-label="Rechercher">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        </button>
                    </form>
                    <button type="button" class="theme-toggle" id="themeToggle" data-theme="light" aria-label="Changer le thème" title="Passer au thème sombre">
                        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                    </button>
                    <ul class="menu">
                        <li><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li><a href="{{ path('app_categories') }}">Catégories</a></li>
                        <li><a href="{{ path('app_about') }}">À propos</a></li>
                        <li><a href="{{ path('app_contact') }}">Contact</a></li>
                        {% if app.user %}
                            <li><a href="{{ path('app_post_my') }}">Mes articles</a></li>
                            <li><a href="{{ path('app_post_create') }}">Rédiger</a></li>
                            <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                        {% else %}
                            <li><a href="{{ path('app_login') }}">Connexion</a></li>
                            <li><a href="{{ path('app_register') }}">Inscription</a></li>
                        {% endif %}
                    </ul>
                </div>
            </nav>
        </header>

        <main>
            {% block breadcrumb %}
                <nav class="breadcrumb" aria-label="Fil d'Ariane">
                    <a href="{{ path('app_home') }}">Accueil</a>
                    {% block breadcrumb_items %}{% endblock %}
                </nav>
            {% endblock %}
            {% block body %}{% endblock %}
        </main>

        <footer role="contentinfo">
            <div class="footer-links">
                <p class="footer-title">Navigation</p>
                <nav class="footer-nav" aria-label="Liens du pied de page">
                    <a href="{{ path('app_home') }}">Accueil</a>
                    <a href="{{ path('app_categories') }}">Catégories</a>
                    <a href="{{ path('app_about') }}">À propos</a>
                    <a href="{{ path('app_contact') }}">Contact</a>
                    {% if app.user %}
                        <a href="{{ path('app_post_my') }}">Mes articles</a>
                        <a href="{{ path('app_post_create') }}">Rédiger un article</a>
                        <a href="{{ path('app_logout') }}">Déconnexion</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Connexion</a>
                        <a href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </nav>
            </div>
            <div class="footer-newsletter">
                <p class="footer-title">Restez informé</p>
                <p class="footer-desc">Recevez les derniers articles par e-mail.</p>
                <form class="newsletter-form" action="#" method="post" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Merci !';">
                    <input type="email" placeholder="votre@email.com" required aria-label="Adresse e-mail">
                    <button type="submit" class="btn">S'inscrire</button>
                </form>
            </div>
            <p class="footer-copy">&copy; {{ 'now'|date('Y') }} Tech Blog. Tous droits réservés.</p>
        </footer>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const themeKey = 'techblog-theme';
                const toggle = document.getElementById('themeToggle');
                const body = document.body;
                const themes = { dark: 'light', light: 'dark' };
                function setTheme(theme) {
                    body.setAttribute('data-theme', theme);
                    toggle.setAttribute('data-theme', theme);
                    toggle.setAttribute('title', theme === 'dark' ? 'Passer au thème clair' : 'Passer au thème sombre');
                    localStorage.setItem(themeKey, theme);
                }
                const saved = localStorage.getItem(themeKey) || 'light';
                setTheme(saved);
                toggle.addEventListener('click', function() { setTheme(themes[body.getAttribute('data-theme')]); });
            });
        </script>
    </body>
</html>
