<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Tech Blog{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%22120%22>⚫</text></svg>">
        <style>
            * { box-sizing: border-box; }
            body { font-family: system-ui, sans-serif; margin: 0; padding: 0; line-height: 1.6; display: flex; flex-direction: column; min-height: 100vh; }
            header { background: #333; color: white; padding: 1rem 2rem; }
            header nav { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; }
            header .logo { height: 40px; }
            header .menu { list-style: none; display: flex; gap: 1.5rem; margin: 0; padding: 0; }
            header a { color: white; text-decoration: none; }
            header a:hover { text-decoration: underline; }
            main { flex: 1; max-width: 1200px; margin: 0 auto; padding: 2rem; width: 100%; }
            footer { background: #333; color: white; text-align: center; padding: 1rem; margin-top: auto; }
            .post-card { border: 1px solid #ddd; padding: 1.5rem; margin-bottom: 1rem; border-radius: 4px; }
            .post-card h2 a { color: #333; }
            .badge { background: #666; color: white; padding: 0.2rem 0.5rem; border-radius: 3px; font-size: 0.85rem; margin-right: 0.3rem; }
            .comment { border-left: 3px solid #333; padding: 1rem; margin: 1rem 0; background: #f9f9f9; }
            .comment-date { color: #666; font-size: 0.9rem; margin-left: 0.5rem; }
            .alert-success { background: #d4edda; color: #155724; padding: 1rem; border-radius: 4px; margin: 1rem 0; }
            .alert-danger, .form-error { background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 4px; margin: 1rem 0; list-style: none; }
            form div { margin: 1rem 0; }
            form label { display: block; margin-bottom: 0.3rem; font-weight: bold; }
            form input, form textarea { width: 100%; max-width: 500px; padding: 0.5rem; }
            .btn { background: #333; color: white; padding: 0.5rem 1rem; border: none; cursor: pointer; border-radius: 4px; }
            .btn:hover { background: #555; }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
        <header role="banner">
            <nav role="navigation" aria-label="Menu principal">
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('images/logo.png') }}" alt="TechTrendz Logo" class="logo">
                </a>
                <ul class="menu">
                    <li><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li><a href="{{ path('app_about') }}">À propos</a></li>
                </ul>
            </nav>
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer role="contentinfo">
            <p>&copy; {{ 'now'|date('Y') }} Tech Blog. Tous droits réservés.</p>
        </footer>
    </body>
</html>
