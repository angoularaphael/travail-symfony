{% extends 'base.html.twig' %}

{% block title %}Accueil - Tech Blog{% endblock %}

{% block body %}
    <h1>Bienvenue sur Tech Blog</h1>
    <p>Découvrez nos derniers articles sur la technologie.</p>

    <section class="posts">
        {% for post in posts %}
            <article class="post-card">
                <h2>
                    <a href="{{ path('app_post_show', {id: post.id}) }}">{{ post.title }}</a>
                </h2>
                <p>{{ post.content|length > 200 ? (post.content|slice(0, 200) ~ '...') : post.content }}</p>
                {% if post.categories|length > 0 %}
                    <div class="categories">
                        {% for category in post.categories %}
                            <span class="badge">{{ category.name }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        {% else %}
            <p>Aucun article pour le moment.</p>
        {% endfor %}
    </section>
{% endblock %}
