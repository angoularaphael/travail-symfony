{% extends 'base.html.twig' %}

{% block title %}Contact - Tech Blog{% endblock %}

{% block breadcrumb_items %}
    <span class="sep">›</span>
    <span>Contact</span>
{% endblock %}

{% block body %}
    <article class="post-detail">
        <h1 class="hero-title">Contact</h1>
        <p class="lead">Une question, une suggestion ou un partenariat ? N'hésitez pas à nous contacter.</p>

        <div class="contact-info">
            <div class="contact-item">
                <strong>Email</strong>
                <p>contact@techblog.com</p>
            </div>
            <div class="contact-item">
                <strong>Réseaux sociaux</strong>
                <p>Suivez-nous pour ne rien manquer de l'actualité tech.</p>
            </div>
        </div>
    </article>
{% endblock %}
