{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - Tech Blog{% endblock %}

{% block breadcrumb_items %}
    <span class="sep">›</span>
    <span>{{ post.title }}</span>
{% endblock %}

{% block body %}
    <article class="post-detail">
        <h1 class="post-title">{{ post.title }}</h1>

        {% if post.categories|length > 0 %}
            <div class="categories">
                {% for category in post.categories %}
                    <a href="{{ path('app_category_show', {id: category.id}) }}" class="badge">{{ category.name }}</a>
                {% endfor %}
            </div>
        {% endif %}

        <div class="post-content">
            {{ post.content|nl2br }}
        </div>
    </article>

    <section class="comments">
        <h2>Commentaires</h2>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {{ form_start(form) }}
            {{ form_errors(form) }}
            {{ form_widget(form) }}
            <button type="submit" class="btn">Publier le commentaire</button>
        {{ form_end(form) }}

        <div class="comments-list">
            {% for comment in post.comments %}
                <div class="comment">
                    <strong>{{ comment.username }}</strong>
                    <span class="comment-date">{{ comment.createdAt|date('d/m/Y H:i') }}</span>
                    <p>{{ comment.content|nl2br }}</p>
                </div>
            {% else %}
                <p class="empty-state">Aucun commentaire pour le moment. Soyez le premier à commenter !</p>
            {% endfor %}
        </div>
    </section>

    <a href="{{ path('app_home') }}" class="back-link">← Retour à l'accueil</a>
{% endblock %}
