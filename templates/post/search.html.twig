{% extends 'base.html.twig' %}

{% block title %}Recherche{% if query %} : {{ query }}{% endif %} - Tech Blog{% endblock %}

{% block breadcrumb_items %}
    <span class="sep">›</span>
    <span>Recherche</span>
{% endblock %}

{% block body %}
    <h1 class="hero-title">Recherche</h1>
    <p class="lead">
        {% if query %}
            {{ posts|length }} résultat(s) pour « {{ query }} »
        {% else %}
            Entrez un mot-clé pour rechercher des articles.
        {% endif %}
    </p>

    <section class="posts">
        {% for post in posts %}
            <article class="post-card">
                <h2>
                    <a href="{{ path('app_post_show', {id: post.id}) }}">{{ post.title }}</a>
                </h2>
                <p>{{ post.content|length > 200 ? (post.content|slice(0, 200) ~ '...') : post.content }}</p>
                {% if post.categories|length > 0 %}
                    <div class="categories">
                        {% for category in post.categories %}
                            <a href="{{ path('app_category_show', {id: category.id}) }}" class="badge">{{ category.name }}</a>
                        {% endfor %}
                    </div>
                {% endif %}
            </article>
        {% else %}
            <p class="empty-state">
                {% if query %}
                    Aucun article trouvé pour « {{ query }} ». Essayez d'autres mots-clés.
                {% else %}
                    Utilisez la barre de recherche ci-dessus pour trouver des articles.
                {% endif %}
            </p>
        {% endfor %}
    </section>
{% endblock %}
